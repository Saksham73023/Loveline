<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>For You ❤️</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: Arial, sans-serif;
      text-align: center;
      background: linear-gradient(135deg, #ffdce6, #ffeef3);
      min-height: 100vh;
    }

    .container {
      padding: 50px 20px;
    }

    h1 {
      color: #d63384;
      margin-bottom: 10px;
    }

    p {
      color: #444;
      font-size: 18px;
    }

    .btns {
      margin-top: 40px;
      position: relative;
      height: 120px;
    }

    button {
      padding: 12px 26px;
      font-size: 18px;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      margin: 10px;
      box-shadow: 0 6px 14px rgba(0,0,0,0.15);
    }

    #yesBtn {
      background: #ff4d88;
      color: white;
    }

    #noBtn {
      background: #333;
      color: white;
      cursor: not-allowed;
      pointer-events: none;
      opacity: 0.7;
    }

    .image-section {
      display: none;
      margin-top: 40px;
    }

    .image-box {
      display: flex;
      justify-content: center;
      gap: 25px;
      flex-wrap: wrap;
      margin-top: 25px;
    }

    .card {
      background: white;
      padding: 15px;
      border-radius: 20px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.12);
      width: 260px;
    }

    .card img {
      width: 100%;
      height: 240px;
      object-fit: cover;
      border-radius: 16px;
      cursor: pointer;
      transition: transform 0.3s ease;
    }

    .card img:hover {
      transform: scale(1.04);
    }

    .card p {
      margin-top: 12px;
      font-weight: bold;
      color: #d63384;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Do You Love Me? ❤️</h1>
    <p>Bas dil se ek baar Yes kar do 😌</p>

    <div class="btns" id="questionBox">
      <button id="yesBtn" onclick="showImages()">Yes 💖</button>
      <button id="noBtn">No 😢</button>
    </div>

    <div class="image-section" id="imageSection">
      <h2 style="color:#d63384;">Ab ek image choose karo 💕</h2>

      <div class="image-box">
        <div class="card">
          <img src="https://images.unsplash.com/photo-1518199266791-5375a83190b7?w=700"
               alt="Shayari 1"
               onclick="openPage('shayari1.html')" />
          <p>Image 1 pe click karo</p>
        </div>

        <div class="card">
          <img src="https://images.unsplash.com/photo-1516589178581-6cd7833ae3b2?w=700"
               alt="Shayari 2"
               onclick="openPage('shayari2.html')" />
          <p>Image 2 pe click karo</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    function showImages() {
      document.getElementById("questionBox").style.display = "none";
      document.getElementById("imageSection").style.display = "block";
    }

    function openPage(page) {
      window.location.href = page;
    }
  </script>
</body>
</html>
